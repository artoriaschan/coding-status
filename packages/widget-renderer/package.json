{
    "name": "@coding-status/widget-renderer",
    "version": "0.0.1",
    "description": "Coding Status Widget rendering library - statusline widget components",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./settings.schema": {
            "types": "./dist/settings.schema.d.ts",
            "import": "./dist/settings.schema.js",
            "default": "./dist/settings.schema.js"
        }
    },
    "files": [
        "dist",
        "schemas"
    ],
    "contributes": {
        "jsonValidation": [
            {
                "fileMatch": [
                    "**/.coding-status/settings.json",
                    "**/settings.json"
                ],
                "url": "./schemas/settings.schema.json"
            }
        ]
    },
    "scripts": {
        "build": "tsc",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "chalk": "^5.3.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "tsx": "^4.21.0",
        "typescript": "^5.4.2",
        "zod-to-json-schema": "^3.25.2"
    },
    "keywords": [
        "coding-status",
        "widget",
        "renderer",
        "statusline"
    ],
    "license": "MIT"
}
