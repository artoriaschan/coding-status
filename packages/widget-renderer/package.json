{
  "name": "@cdps/widget-renderer",
  "version": "0.0.1",
  "description": "CDPS Widget rendering library - statusline widget components",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./settings.schema": {
      "import": "./dist/settings.schema.js",
      "types": "./dist/settings.schema.d.ts"
    }
  },
  "files": ["dist", "schemas"],
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": ["**/.cdps/settings.json", "**/settings.json"],
        "url": "./schemas/settings.schema.json"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "keywords": [
    "cdps",
    "widget",
    "renderer",
    "statusline"
  ],
  "license": "MIT"
}
