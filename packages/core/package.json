{
  "name": "@cdps/core",
  "version": "0.0.1",
  "description": "CDPS CLI core - cloud provider usage statusline tool",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cdps": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schemas"
  ],
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": [
          "**/.cdps/config.json",
          "**/config.json"
        ],
        "url": "./schemas/config.schema.json"
      }
    ]
  },
  "scripts": {
    "build": "pnpm generate-schemas && tsc",
    "generate-schemas": "tsx scripts/generate-schemas.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@cdps/widget-renderer": "workspace:*",
    "@clack/prompts": "^0.10.0",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "parse-json": "^8.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude-code",
    "statusline",
    "api-usage"
  ],
  "license": "MIT"
}
