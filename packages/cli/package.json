{
    "name": "cdps",
    "version": "0.0.1",
    "description": "Cloud provider usage statusline for Claude Code",
    "type": "module",
    "bin": {
        "cdps": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts --clean",
        "dev": "tsx src/index.ts",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "@cdps/core": "workspace:*"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "tsx": "^4.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/artoriaschan/coding-plans-statusline.git"
    },
    "bugs": {
        "url": "https://github.com/artoriaschan/coding-plans-statusline/issues"
    },
    "homepage": "https://github.com/artoriaschan/coding-plans-statusline#readme"
}
