{
    "name": "@coding-status/cli",
    "version": "0.0.1",
    "description": "Coding Status CLI - cloud provider usage statusline tool",
    "type": "module",
    "bin": {
        "coding-status": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "schemas"
    ],
    "contributes": {
        "jsonValidation": [
            {
                "fileMatch": [
                    "**/.coding-status/config.json",
                    "**/config.json"
                ],
                "url": "./schemas/config.schema.json"
            }
        ]
    },
    "scripts": {
        "build": "pnpm generate-schemas && tsup src/index.ts --format esm --dts --clean",
        "generate-schemas": "tsx scripts/generate-schemas.ts",
        "dev": "tsx src/index.ts",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "@coding-status/widget-renderer": "workspace:*",
        "@clack/prompts": "^0.10.0",
        "chalk": "^5.3.0",
        "commander": "^13.0.0",
        "parse-json": "^8.3.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "tsx": "^4.21.0",
        "typescript": "^5.4.2",
        "tsup": "^8.0.0",
        "zod-to-json-schema": "^3.25.2"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "claude-code",
        "statusline",
        "cloud-usage",
        "coding-status"
    ],
    "license": "MIT"
}
