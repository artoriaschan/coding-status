{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://coding-status.dev/schemas/config.schema.json",
  "title": "Coding Status Configuration",
  "description": "Configuration for coding-status CLI - cloud provider usage statusline",
  "$ref": "#/definitions/CDPSConfig",
  "definitions": {
    "CDPSConfig": {
      "type": "object",
      "properties": {
        "providers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 32
              },
              "type": {
                "type": "string",
                "enum": [
                  "bailian"
                ]
              },
              "packageName": {
                "type": "string",
                "minLength": 1
              },
              "credentials": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": [
              "name",
              "type",
              "packageName",
              "credentials"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "current": {
          "type": "string"
        },
        "cacheTtl": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "default": 300
        }
      },
      "additionalProperties": false
    }
  }
}
