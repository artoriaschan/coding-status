{
    "name": "@coding-status/usage-adapter-bailian",
    "version": "0.0.1",
    "description": "Aliyun Bailian usage adapter for Coding Status",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "types"
    ],
    "scripts": {
        "build": "tsup && tsc -p tsconfig.build.json",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "@alicloud/cms20190101": "^4.0.0",
        "@alicloud/openapi-core": "^1.0.0",
        "@coding-status/cli": "workspace:*",
        "@coding-status/widget-renderer": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "tsup": "^8.5.1",
        "typescript": "^5.4.2"
    },
    "keywords": [
        "coding-status",
        "adapter",
        "bailian",
        "aliyun"
    ],
    "license": "MIT"
}
